{
  "name": "agent-teams-guide",
  "private": true,
  "version": "0.10.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "electron:dev": "vite build --config vite.config.electron.mjs && electron .",
    "electron:build": "vite build --config vite.config.electron.mjs && electron-builder --win",
    "electron:patch": "node scripts/build-patch.cjs",
    "build:pixel-agents": "node scripts/build-pixel-agents.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.577.0",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hotkeys-hook": "^5.3.3",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.27",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "puppeteer": "^24.38.0",
    "tailwindcss": "^3.4.19",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.internal.agent-teams-guide",
    "productName": "Claude Agent Teams",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "electron/**/*",
      "!electron/prompts/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/prompts",
        "to": "prompts"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
